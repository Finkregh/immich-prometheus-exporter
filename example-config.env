# Example environment variables for Immich Prometheus Exporter
# Copy this file to .env and modify the values

# Immich server URL (required)
IMMICH_URL=http://localhost:2283

# Immich API key (required)
# Get this from your Immich web interface: Account Settings → API Keys
IMMICH_API_KEY=your-api-key-here

# Optional: Output file path
# If not set, metrics will be printed to stdout
# IMMICH_OUTPUT_FILE=/tmp/immich_metrics.txt

# Optional: Export interval in seconds for continuous mode
# If not set, will run once and exit
# IMMICH_INTERVAL=60
