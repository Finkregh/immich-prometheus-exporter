# Example environment variables for Immich Prometheus Exporter
# Copy this file to .env and modify the values

# =============================================================================
# EXPORT COMMAND ENVIRONMENT VARIABLES
# =============================================================================

# Immich server URL (required)
IMMICHEXPORTER_EXPORT_URL=http://localhost:2283

# Immich API key (required)
# Get this from your Immich web interface: Account Settings → API Keys
IMMICHEXPORTER_EXPORT_API_KEY=your-api-key-here

# Optional: Output file path
# If not set, metrics will be printed to stdout
# IMMICHEXPORTER_EXPORT_OUTPUT=/tmp/immich_metrics.txt

# Optional: Export interval in seconds for continuous mode
# If not set, will run once and exit
# IMMICHEXPORTER_EXPORT_INTERVAL=60

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# IMMICHEXPORTER_EXPORT_LOG_LEVEL=INFO

# Optional: Log file path (if not set, logs to stderr)
# IMMICHEXPORTER_EXPORT_LOG_FILE=/tmp/immich_exporter.log

# Optional: Log to stdout instead of stderr (requires output file to be set)
# IMMICHEXPORTER_EXPORT_LOG_TO_STDOUT=false

# =============================================================================
# SERVE COMMAND ENVIRONMENT VARIABLES
# =============================================================================

# Immich server URL (required)
# IMMICHEXPORTER_SERVE_URL=http://localhost:2283

# Immich API key (required)
# IMMICHEXPORTER_SERVE_API_KEY=your-api-key-here

# Optional: Port to serve metrics on (default: 8000)
# IMMICHEXPORTER_SERVE_PORT=8000

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# IMMICHEXPORTER_SERVE_LOG_LEVEL=INFO

# Optional: Log file path (if not set, logs to stderr)
# IMMICHEXPORTER_SERVE_LOG_FILE=/tmp/immich_exporter.log

# =============================================================================
# TEST CONNECTION COMMAND ENVIRONMENT VARIABLES
# =============================================================================

# Immich server URL (required)
# IMMICHEXPORTER_TEST_CONNECTION_URL=http://localhost:2283

# Immich API key (required)
# IMMICHEXPORTER_TEST_CONNECTION_API_KEY=your-api-key-here
